{
  "name": "surau-collab-server",
  "version": "0.1.0",
  "private": true,
  "description": "Realtime collaborative editing server (Yjs/Hocuspocus) for the Surau kitab editor",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@hocuspocus/extension-database": "^4.1.1",
    "@hocuspocus/server": "^4.1.1",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-subscript": "^3.26.0",
    "@tiptap/extension-superscript": "^3.26.0",
    "@tiptap/extension-table": "^3.26.0",
    "@tiptap/html": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "pg": "^8.16.0",
    "pino": "^9.6.0",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.27",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@hocuspocus/provider": "^4.1.1",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
