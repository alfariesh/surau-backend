# App
APP_NAME=go-clean-template
APP_VERSION=1.0.0
# HTTP settings
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false
# Logger
LOG_LEVEL=debug
# PG
PG_POOL_MAX=2
PG_URL=postgres://user:myAwEsOm3pa55@w0rd@localhost:5432/db
# Metrics
METRICS_ENABLED=true
# Swagger
SWAGGER_ENABLED=true
# JWT
JWT_TOKEN_EXPIRY=24h
JWT_SECRET=dev-secret-change-me-32-bytes-minimum
JWT_ISSUER=surau-backend
JWT_AUDIENCE=surau-api
# Auth DB-backed rate limits
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_LOGIN_EMAIL_MAX=5
AUTH_RATE_LIMIT_LOGIN_EMAIL_WINDOW=5m
AUTH_RATE_LIMIT_LOGIN_IP_MAX=30
AUTH_RATE_LIMIT_LOGIN_IP_WINDOW=5m
AUTH_RATE_LIMIT_REGISTER_EMAIL_MAX=3
AUTH_RATE_LIMIT_REGISTER_EMAIL_WINDOW=1h
AUTH_RATE_LIMIT_REGISTER_IP_MAX=10
AUTH_RATE_LIMIT_REGISTER_IP_WINDOW=1h
AUTH_RATE_LIMIT_FORGOT_PASSWORD_EMAIL_MAX=3
AUTH_RATE_LIMIT_FORGOT_PASSWORD_EMAIL_WINDOW=1h
AUTH_RATE_LIMIT_FORGOT_PASSWORD_IP_MAX=20
AUTH_RATE_LIMIT_FORGOT_PASSWORD_IP_WINDOW=1h
AUTH_RATE_LIMIT_RESEND_VERIFICATION_EMAIL_MAX=3
AUTH_RATE_LIMIT_RESEND_VERIFICATION_EMAIL_WINDOW=1h
AUTH_RATE_LIMIT_RESEND_VERIFICATION_IP_MAX=20
AUTH_RATE_LIMIT_RESEND_VERIFICATION_IP_WINDOW=1h
AUTH_RATE_LIMIT_RESET_PASSWORD_TOKEN_MAX=5
AUTH_RATE_LIMIT_RESET_PASSWORD_TOKEN_WINDOW=15m
AUTH_RATE_LIMIT_RESET_PASSWORD_IP_MAX=30
AUTH_RATE_LIMIT_RESET_PASSWORD_IP_WINDOW=15m
AUTH_RATE_LIMIT_CHANGE_PASSWORD_USER_MAX=5
AUTH_RATE_LIMIT_CHANGE_PASSWORD_USER_WINDOW=5m
AUTH_RATE_LIMIT_CHANGE_PASSWORD_IP_MAX=30
AUTH_RATE_LIMIT_CHANGE_PASSWORD_IP_WINDOW=5m
AUTH_RATE_LIMIT_CHANGE_EMAIL_USER_MAX=3
AUTH_RATE_LIMIT_CHANGE_EMAIL_USER_WINDOW=1h
AUTH_RATE_LIMIT_CHANGE_EMAIL_IP_MAX=10
AUTH_RATE_LIMIT_CHANGE_EMAIL_IP_WINDOW=1h
AUTH_RATE_LIMIT_CHANGE_EMAIL_TOKEN_MAX=5
AUTH_RATE_LIMIT_CHANGE_EMAIL_TOKEN_WINDOW=15m
AUTH_RATE_LIMIT_DELETE_ACCOUNT_USER_MAX=3
AUTH_RATE_LIMIT_DELETE_ACCOUNT_USER_WINDOW=1h
AUTH_RATE_LIMIT_DELETE_ACCOUNT_IP_MAX=10
AUTH_RATE_LIMIT_DELETE_ACCOUNT_IP_WINDOW=1h
# Auth security email notifications
AUTH_EMAIL_NOTIFICATIONS_ENABLED=true
AUTH_FAILED_LOGIN_EMAIL_COOLDOWN=24h
AUTH_NEW_LOGIN_EMAIL_ENABLED=true
AUTH_FAILED_LOGIN_EMAIL_ENABLED=true
AUTH_PASSWORD_CHANGED_EMAIL_ENABLED=true
AUTH_EMAIL_VERIFIED_EMAIL_ENABLED=true
AUTH_ROLE_CHANGED_EMAIL_ENABLED=true
AUTH_EMAIL_CHANGED_EMAIL_ENABLED=true
AUTH_ACCOUNT_DELETED_EMAIL_ENABLED=true
# Email. Use "log" locally to print verification/reset links to app logs.
EMAIL_DELIVERY_MODE=log
CF_EMAIL_ACCOUNT_ID=dev-cloudflare-account-id
CF_EMAIL_API_TOKEN=dev-cloudflare-api-token
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=Surau
EMAIL_REPLY_TO=
EMAIL_VERIFY_FRONTEND_URL=http://localhost:3005/verify-email
EMAIL_VERIFICATION_TTL=24h
EMAIL_RESEND_COOLDOWN=1m
PASSWORD_RESET_FRONTEND_URL=http://localhost:3005/reset-password
PASSWORD_RESET_TTL=1h
PASSWORD_RESET_RESEND_COOLDOWN=1m
EMAIL_CHANGE_FRONTEND_URL=http://localhost:3005/change-email
EMAIL_CHANGE_TTL=24h
EMAIL_CHANGE_RESEND_COOLDOWN=1m
EMAIL_HTTP_TIMEOUT=10s
# Book RAG
RAG_LLM_BASE_URL=https://ai.sumopod.com/v1
RAG_LLM_API_KEY=
RAG_LLM_MODEL=glm-5.1
RAG_LLM_TIMEOUT=45s
RAG_LLM_MAX_TOKENS=1400
RAG_LLM_TEMPERATURE=0.1
RAG_MAX_CONTEXT_PAGES=8
RAG_TREE_FULL_MAX_NODES=450
RAG_TREE_BLOCK_MAX_NODES=120
RAG_TREE_BEAM_SIZE=3
RAG_TREE_MAX_TURNS=6
RAG_TREE_MAX_BLOCKS_PER_TURN=6
SUMMARY_LLM_BASE_URL=https://ai.sumopod.com/v1
SUMMARY_LLM_API_KEY=
SUMMARY_LLM_MODEL=glm-5.1
