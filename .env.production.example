# Copy this file to .env.production on the server and replace every CHANGE_ME value.

# App
APP_NAME=surau-backend
APP_VERSION=1.0.0
# Deployment environment surfaced by GET /version. Set 'prod' on the prod VPS and
# 'dev' on the dev VPS. The deploy workflow overrides APP_VERSION with the git tag.
APP_ENV=prod
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false
# Client IP resolution. Production runs Cloudflare -> Caddy -> app, so the real
# visitor IP comes from the CF-Connecting-IP header. TRUSTED_PROXIES is the hop
# the app actually sees (the Docker gateway, e.g. 172.18.0.1). Behind a plain
# proxy instead of Cloudflare, use X-Real-IP. Leave TRUSTED_PROXIES empty only
# if the app is exposed directly (headers are then ignored to prevent spoofing).
# SECURITY: also restrict Caddy's :80/:443 to Cloudflare IP ranges, otherwise
# CF-Connecting-IP can be spoofed by hitting the origin directly.
HTTP_PROXY_HEADER=CF-Connecting-IP
HTTP_TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
HTTP_BODY_LIMIT_BYTES=4194304
# Gzip/deflate/brotli response compression (negotiated via Accept-Encoding).
HTTP_COMPRESSION_ENABLED=true
# Browser origins of the web frontend (scheme://host, no path). Native mobile
# apps do not need CORS; leave empty if no browser client exists yet.
CORS_ALLOWED_ORIGINS=https://CHANGE_ME_FRONTEND_DOMAIN
# Security response headers. HSTS is safe here because production is always
# behind Cloudflare/Caddy TLS.
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_SECONDS=31536000
LOG_LEVEL=info
METRICS_ENABLED=false
SWAGGER_ENABLED=false

# Realtime collaborative editing (Yjs/Hocuspocus sidecar, see docs/collab.md).
# Generate the token with: openssl rand -base64 32. Setting COLLAB_ENABLED=true
# makes the deploy workflow start the collab service too (compose profile
# "collab"); Caddy must proxy /collab to 127.0.0.1:8090 and 404 /internal.
COLLAB_ENABLED=false
COLLAB_SERVICE_TOKEN=CHANGE_ME_COLLAB_SERVICE_TOKEN_32B

# Database
POSTGRES_USER=surau
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=surau
PG_POOL_MAX=10
PG_MAX_CONN_LIFETIME=1h
PG_MAX_CONN_IDLE_TIME=30m
PG_URL=postgres://surau:CHANGE_ME_DB_PASSWORD@db:5432/surau?sslmode=disable
# Postgres server tuning (F1-G) — set per host RAM (dev VPS 2GB → keep the
# compose defaults / values below commented; prod VPS 4GB → uncomment the
# larger values). Rollout: docs/deploy-vps.md §Tuning Postgres
# (manual `up -d db` + `pgbackrest check`).
#PG_SHARED_BUFFERS=512MB
#PG_EFFECTIVE_CACHE_SIZE=2GB
#PG_WORK_MEM=6MB
#PG_MAINTENANCE_WORK_MEM=128MB
#PG_MAX_CONNECTIONS=50
#PG_LOG_MIN_DURATION=200ms

# Auth
JWT_TOKEN_EXPIRY=24h
# Access tokens are short-lived; clients renew them via POST /auth/refresh.
# Raise to 24h temporarily if the frontend has not shipped refresh support yet.
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=720h
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES
JWT_ISSUER=surau-backend
JWT_AUDIENCE=surau-api
# Progressive login lockout (per email key, escalating backoff)
AUTH_LOCKOUT_ENABLED=true
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_BASE_DURATION=1m
AUTH_LOCKOUT_FACTOR=15
AUTH_LOCKOUT_MAX_DURATION=1h
# Periodic cleanup of expired auth rows. Sessions rotate on every refresh, so
# keep AUTH_CLEANUP_SESSION_RETENTION short in production (7d is plenty).
AUTH_CLEANUP_ENABLED=true
AUTH_CLEANUP_INTERVAL=6h
AUTH_CLEANUP_TOKEN_RETENTION=720h
AUTH_CLEANUP_SESSION_RETENTION=168h
# 0 keeps audit logs forever
AUTH_CLEANUP_AUDIT_RETENTION=0
# Admin alerting for refresh-token reuse (likely token theft). Enable in prod
# and set explicit recipients; empty AUTH_ALERT_RECIPIENTS falls back to all
# admin-role users.
AUTH_ALERT_ENABLED=true
AUTH_ALERT_INTERVAL=5m
AUTH_ALERT_RECIPIENTS=security@surau.org
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_LOGIN_EMAIL_MAX=5
AUTH_RATE_LIMIT_LOGIN_EMAIL_WINDOW=5m
AUTH_RATE_LIMIT_LOGIN_IP_MAX=30
AUTH_RATE_LIMIT_LOGIN_IP_WINDOW=5m
AUTH_RATE_LIMIT_REGISTER_EMAIL_MAX=3
AUTH_RATE_LIMIT_REGISTER_EMAIL_WINDOW=1h
AUTH_RATE_LIMIT_REGISTER_IP_MAX=10
AUTH_RATE_LIMIT_REGISTER_IP_WINDOW=1h
AUTH_RATE_LIMIT_FORGOT_PASSWORD_EMAIL_MAX=3
AUTH_RATE_LIMIT_FORGOT_PASSWORD_EMAIL_WINDOW=1h
AUTH_RATE_LIMIT_FORGOT_PASSWORD_IP_MAX=20
AUTH_RATE_LIMIT_FORGOT_PASSWORD_IP_WINDOW=1h
AUTH_RATE_LIMIT_RESEND_VERIFICATION_EMAIL_MAX=3
AUTH_RATE_LIMIT_RESEND_VERIFICATION_EMAIL_WINDOW=1h
AUTH_RATE_LIMIT_RESEND_VERIFICATION_IP_MAX=20
AUTH_RATE_LIMIT_RESEND_VERIFICATION_IP_WINDOW=1h
AUTH_RATE_LIMIT_RESET_PASSWORD_TOKEN_MAX=5
AUTH_RATE_LIMIT_RESET_PASSWORD_TOKEN_WINDOW=15m
AUTH_RATE_LIMIT_RESET_PASSWORD_IP_MAX=30
AUTH_RATE_LIMIT_RESET_PASSWORD_IP_WINDOW=15m
AUTH_RATE_LIMIT_CHANGE_PASSWORD_USER_MAX=5
AUTH_RATE_LIMIT_CHANGE_PASSWORD_USER_WINDOW=5m
AUTH_RATE_LIMIT_CHANGE_PASSWORD_IP_MAX=30
AUTH_RATE_LIMIT_CHANGE_PASSWORD_IP_WINDOW=5m
AUTH_RATE_LIMIT_CHANGE_EMAIL_USER_MAX=3
AUTH_RATE_LIMIT_CHANGE_EMAIL_USER_WINDOW=1h
AUTH_RATE_LIMIT_CHANGE_EMAIL_IP_MAX=10
AUTH_RATE_LIMIT_CHANGE_EMAIL_IP_WINDOW=1h
AUTH_RATE_LIMIT_CHANGE_EMAIL_TOKEN_MAX=5
AUTH_RATE_LIMIT_CHANGE_EMAIL_TOKEN_WINDOW=15m
AUTH_RATE_LIMIT_DELETE_ACCOUNT_USER_MAX=3
AUTH_RATE_LIMIT_DELETE_ACCOUNT_USER_WINDOW=1h
AUTH_RATE_LIMIT_DELETE_ACCOUNT_IP_MAX=10
AUTH_RATE_LIMIT_DELETE_ACCOUNT_IP_WINDOW=1h

# Auth security email notifications
AUTH_EMAIL_NOTIFICATIONS_ENABLED=true
AUTH_FAILED_LOGIN_EMAIL_COOLDOWN=24h
AUTH_NEW_LOGIN_EMAIL_ENABLED=true
AUTH_FAILED_LOGIN_EMAIL_ENABLED=true
AUTH_PASSWORD_CHANGED_EMAIL_ENABLED=true
AUTH_EMAIL_VERIFIED_EMAIL_ENABLED=true
AUTH_ROLE_CHANGED_EMAIL_ENABLED=true
AUTH_EMAIL_CHANGED_EMAIL_ENABLED=true
AUTH_ACCOUNT_DELETED_EMAIL_ENABLED=true

# Email / Cloudflare Email Service
EMAIL_DELIVERY_MODE=cloudflare
CF_EMAIL_ACCOUNT_ID=CHANGE_ME_CLOUDFLARE_ACCOUNT_ID
CF_EMAIL_API_TOKEN=CHANGE_ME_CLOUDFLARE_EMAIL_API_TOKEN
EMAIL_FROM_ADDRESS=noreply@mail.surau.org
EMAIL_FROM_NAME=Surau
EMAIL_REPLY_TO=
EMAIL_VERIFY_FRONTEND_URL=https://surau.org/verify-email
EMAIL_VERIFICATION_TTL=24h
EMAIL_RESEND_COOLDOWN=1m
PASSWORD_RESET_FRONTEND_URL=https://surau.org/reset-password
PASSWORD_RESET_TTL=1h
PASSWORD_RESET_RESEND_COOLDOWN=1m
EMAIL_CHANGE_FRONTEND_URL=https://surau.org/change-email
EMAIL_CHANGE_TTL=24h
EMAIL_CHANGE_RESEND_COOLDOWN=1m
EMAIL_UNSUBSCRIBE_FRONTEND_URL=https://surau.org/unsubscribe
EMAIL_UNSUBSCRIBE_PUBLIC_URL=https://api.surau.org/v1/email/unsubscribe
EMAIL_CLOUDFLARE_EVENT_POLLING_ENABLED=false
EMAIL_CLOUDFLARE_ZONE_ID=CHANGE_ME_CLOUDFLARE_ZONE_ID
EMAIL_CLOUDFLARE_ANALYTICS_API_TOKEN=CHANGE_ME_CLOUDFLARE_GRAPHQL_ANALYTICS_TOKEN
EMAIL_CLOUDFLARE_EVENT_POLLING_INTERVAL=5m
EMAIL_CLOUDFLARE_EVENT_POLLING_LOOKBACK=30m
EMAIL_CLOUDFLARE_EVENT_POLLING_LIMIT=100
EMAIL_HTTP_TIMEOUT=10s
# Background dispatcher pace for queued transactional/campaign emails. Auth
# emails (verification, reset) are enqueued, so this bounds their latency.
EMAIL_DISPATCH_INTERVAL=15s
EMAIL_DISPATCH_BATCH=20

# OneSignal push notifications. The REST API key is a SECRET — inject it from the secret store, never
# commit a real value. The App ID is public (also embedded in the Android app).
ONESIGNAL_ENABLED=true
ONESIGNAL_APP_ID=7a650cae-1c1e-4b19-a7fe-393c14b894f0
ONESIGNAL_REST_API_KEY=CHANGE_ME_ONESIGNAL_REST_API_KEY
ONESIGNAL_HTTP_TIMEOUT=10s

# Book RAG
RAG_LLM_BASE_URL=https://ai.sumopod.com/v1
# AI Gateway custom provider example:
# RAG_LLM_BASE_URL=https://gateway.ai.cloudflare.com/v1/CHANGE_ME_ACCOUNT_ID/surau-rag/CHANGE_ME_CUSTOM_PROVIDER_SLUG/v1
RAG_LLM_API_KEY=CHANGE_ME_RAG_LLM_API_KEY
RAG_LLM_MODEL=glm-5.1
RAG_LLM_TIMEOUT=45s
RAG_LLM_MAX_TOKENS=1400
RAG_LLM_TEMPERATURE=0.1
RAG_MAX_CONTEXT_PAGES=8
RAG_TREE_FULL_MAX_NODES=450
RAG_TREE_BLOCK_MAX_NODES=120
RAG_TREE_BEAM_SIZE=3
RAG_TREE_MAX_TURNS=6
RAG_TREE_MAX_BLOCKS_PER_TURN=6
SUMMARY_LLM_BASE_URL=https://ai.sumopod.com/v1
SUMMARY_LLM_API_KEY=CHANGE_ME_SUMMARY_LLM_API_KEY
SUMMARY_LLM_MODEL=glm-5.1

# Compose
APP_IMAGE=surau-backend:latest
APP_BIND_ADDR=127.0.0.1
APP_PUBLISHED_PORT=8080

# Observability (F1-B). METRICS_ENABLED exposes /metrics on the compose
# network only (the edge keeps returning 404).
METRICS_ENABLED=true
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_TRACE_SAMPLE_RATIO=1.0
# Grafana (profile: observability). ROOT_URL must end with /grafana/.
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN
GRAFANA_ROOT_URL=https://dev-api.surau.org/grafana/
GRAFANA_BIND_ADDR=127.0.0.1
GRAFANA_PUBLISHED_PORT=3000
# Telegram alarm channel (same bot as ops/backup) + environment label.
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_TOKEN
TELEGRAM_CHAT_ID=CHANGE_ME_CHAT_ID
OBS_ENV_LABEL=dev
