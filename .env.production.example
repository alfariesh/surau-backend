# Copy this file to .env.production on the server and replace every CHANGE_ME value.

# App
APP_NAME=surau-backend
APP_VERSION=1.0.0
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false
LOG_LEVEL=info
METRICS_ENABLED=false
SWAGGER_ENABLED=false

# Database
POSTGRES_USER=surau
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=surau
PG_POOL_MAX=10
PG_URL=postgres://surau:CHANGE_ME_DB_PASSWORD@db:5432/surau?sslmode=disable

# Auth
JWT_TOKEN_EXPIRY=24h
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Compose
APP_IMAGE=surau-backend:latest
APP_BIND_ADDR=127.0.0.1
APP_PUBLISHED_PORT=8080
