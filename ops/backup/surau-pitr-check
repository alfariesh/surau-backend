#!/usr/bin/env bash
# End-to-end WAL archiving check: `pgbackrest check` forces a WAL switch and
# verifies the segment actually lands in the R2 repo. Silent archiving death
# (misconfig, credential rot, R2 outage) surfaces here within 6h via OnFailure.
set -Eeuo pipefail

ENV_FILE="${BACKUP_ENV_FILE:-/etc/surau-backup/env}"
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_FILE"
fi

DEPLOY_PATH="${DEPLOY_PATH:-/srv/surau/backend}"
COMPOSE_ENV_FILE="${COMPOSE_ENV_FILE:-.env.production}"
COMPOSE_FILE="${COMPOSE_FILE:-docker-compose.prod.yml}"

cd "$DEPLOY_PATH"
sudo docker compose --env-file "$COMPOSE_ENV_FILE" -f "$COMPOSE_FILE" exec -T -u postgres db \
  pgbackrest --stanza=main check </dev/null
echo "pgbackrest check passed"
