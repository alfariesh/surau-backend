# Copy to /etc/surau-backup/pgbackrest.conf on the VPS.
# Must be readable by the postgres user INSIDE the db container (uid of
# postgres in postgres:18.4-alpine): chown <container-postgres-uid> + chmod 400.
# Mounted read-only into the container at /etc/pgbackrest/pgbackrest.conf.

[global]
repo1-type=s3
repo1-s3-bucket=surau-backend-backups
repo1-s3-endpoint=8be116534f7237b451f28adec91fbbbd.r2.cloudflarestorage.com
repo1-s3-region=auto
repo1-s3-uri-style=path
repo1-s3-key=
repo1-s3-key-secret=
# /pitr/prod on the prod VPS, /pitr/dev on the dev VPS.
repo1-path=/pitr/prod
# ~2 weekly fulls retained; WAL needed by them is kept automatically.
repo1-retention-full=2
# Repo encryption: passphrase lives here (host) — separate from R2 credentials,
# never in the bucket. Keep an offline escrow copy (password manager).
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass=
# Bundle small files to keep R2 request counts sane.
repo1-bundle=y
compress-type=zst
start-fast=y
log-level-console=info
log-level-file=off

[main]
# PGDATA of the postgres:18 official image layout (verify with `echo $PGDATA`
# inside the container).
pg1-path=/var/lib/postgresql/18/docker
# The cluster superuser is $POSTGRES_USER (not "postgres"), so tell pgBackRest
# which role and maintenance db to connect with.
pg1-user=surau
pg1-database=postgres
