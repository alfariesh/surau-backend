#!/usr/bin/env bash
# Point-in-time restore of the pgBackRest repo into a TEMPORARY postgres
# container (never touches the live db). Used for PITR drills and real
# incidents — see docs/backup-restore-r2.md.
#
# Usage:
#   surau-pg-pitr-restore '<YYYY-MM-DD HH:MM:SS+TZ>' ['<verify SQL>' ...]
#
# Each extra argument is a SQL statement executed against the restored
# database with its output printed (used by drills to assert marker rows).
# Set KEEP_CONTAINER=1 to keep the restored instance running for inspection
# (e.g. to pg_dump specific rows during a real incident).
set -Eeuo pipefail

ENV_FILE="${BACKUP_ENV_FILE:-/etc/surau-backup/env}"
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_FILE"
fi

RESTORE_IMAGE="${RESTORE_IMAGE:-surau-db:latest}"
PGBACKREST_CONF="${PGBACKREST_CONF:-/etc/surau-backup/pgbackrest.conf}"
RESTORE_DB="${RESTORE_DB:-surau}"
RESTORE_USER="${RESTORE_USER:-surau}"
KEEP_CONTAINER="${KEEP_CONTAINER:-0}"
RECOVERY_TIMEOUT_SECS="${RECOVERY_TIMEOUT_SECS:-900}"

# Accepts "2026-07-07 12:34:56", optional fractional seconds and offset ("+08", "+08:00").
TIME_PATTERN='^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}(\.[0-9]+)?([+-][0-9]{2}(:?[0-9]{2})?)?$'

target_time="${1:-}"
if [[ -z "$target_time" ]]; then
  echo "usage: surau-pg-pitr-restore '<YYYY-MM-DD HH:MM:SS+TZ>' ['<verify SQL>' ...]" >&2
  exit 2
fi
if ! [[ "$target_time" =~ $TIME_PATTERN ]]; then
  echo "invalid target time: '${target_time}' (expected e.g. '2026-07-07 12:34:56+08')" >&2
  exit 2
fi
shift

if [[ ! -f "$PGBACKREST_CONF" ]]; then
  echo "pgbackrest config not found: ${PGBACKREST_CONF}" >&2
  exit 2
fi

started_epoch="$(date +%s)"
CONTAINER="surau-pitr-restore-$(date -u +%Y%m%d%H%M%S)"
VOLUME="${CONTAINER}-data"

cleanup() {
  if [[ "$KEEP_CONTAINER" == "1" ]]; then
    echo "KEEP_CONTAINER=1 — restored instance left running: ${CONTAINER}"
    return
  fi
  sudo docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
  sudo docker volume rm -f "$VOLUME" >/dev/null 2>&1 || true
}
trap cleanup EXIT

sudo docker volume create "$VOLUME" >/dev/null
echo "starting temporary restore container: ${CONTAINER}"
sudo docker run -d --name "$CONTAINER" \
  --entrypoint sleep \
  -v "${VOLUME}:/var/lib/postgresql" \
  -v "${PGBACKREST_CONF}:/etc/pgbackrest/pgbackrest.conf:ro" \
  "$RESTORE_IMAGE" infinity >/dev/null

pgdata="$(sudo docker exec "$CONTAINER" sh -c 'echo "$PGDATA"')"
if [[ -z "$pgdata" ]]; then
  echo "could not determine PGDATA from image ${RESTORE_IMAGE}" >&2
  exit 5
fi
sudo docker exec "$CONTAINER" sh -c "mkdir -p '$pgdata' && chown -R postgres:postgres /var/lib/postgresql && chmod 700 '$pgdata'"

echo "pgbackrest restore --type=time --target='${target_time}' (this downloads the base backup + WAL from R2)"
sudo docker exec -u postgres "$CONTAINER" \
  pgbackrest --stanza=main restore --type=time --target="$target_time" --target-action=promote

# The restored cluster starts with archive_mode from postgresql.conf (off in
# our setup — archiving is injected via compose command flags on the LIVE db
# only), so this instance can never pollute the WAL archive.
echo "starting postgres for WAL replay to target time"
sudo docker exec -d -u postgres "$CONTAINER" postgres

ready=false
for _ in $(seq 1 "$RECOVERY_TIMEOUT_SECS"); do
  if [[ "$(sudo docker exec -u postgres "$CONTAINER" psql -U "$RESTORE_USER" -d "$RESTORE_DB" -Atc 'select pg_is_in_recovery()' 2>/dev/null || true)" == "f" ]]; then
    ready=true
    break
  fi
  sleep 1
done
if [[ "$ready" != true ]]; then
  echo "restored instance did not finish recovery within ${RECOVERY_TIMEOUT_SECS}s" >&2
  sudo docker logs "$CONTAINER" 2>&1 | tail -30 >&2 || true
  exit 5
fi

echo "recovery complete — promoted at target '${target_time}'"

books="$(sudo docker exec -u postgres "$CONTAINER" psql -U "$RESTORE_USER" -d "$RESTORE_DB" -Atc "select count(*) from books where has_content = true")"
pages="$(sudo docker exec -u postgres "$CONTAINER" psql -U "$RESTORE_USER" -d "$RESTORE_DB" -Atc "select count(*) from book_pages")"
ayahs="$(sudo docker exec -u postgres "$CONTAINER" psql -U "$RESTORE_USER" -d "$RESTORE_DB" -Atc "select count(*) from quran_ayahs")"
echo "invariant counts: books_with_content=${books} book_pages=${pages} quran_ayahs=${ayahs}"
if [[ "$books" -lt 1 || "$pages" -lt 1 || "$ayahs" -ne 6236 ]]; then
  echo "PITR restore failed invariant validation" >&2
  exit 4
fi

for sql in "$@"; do
  out="$(sudo docker exec -u postgres "$CONTAINER" psql -U "$RESTORE_USER" -d "$RESTORE_DB" -Atc "$sql")"
  echo "verify [${sql}] => ${out:-<empty>}"
done

duration=$(( $(date +%s) - started_epoch ))
echo "PITR restore to '${target_time}' passed in ${duration}s"
