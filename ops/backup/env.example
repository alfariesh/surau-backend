# Copy to /etc/surau-backup/env on the VPS and chmod 600.

# Environment label used as prefix in Telegram messages: prod / dev.
ENV_LABEL=prod

DEPLOY_PATH=/srv/surau/backend
COMPOSE_ENV_FILE=.env.production
COMPOSE_FILE=docker-compose.prod.yml
BACKUP_DIR=/var/backups/surau/postgres
LOCAL_RETENTION_DAYS=7

R2_ACCOUNT_ID=8be116534f7237b451f28adec91fbbbd
R2_BUCKET=surau-backend-backups
# postgres/prod on the prod VPS, postgres/dev on the dev VPS.
R2_PREFIX=postgres/prod
R2_ENDPOINT=https://8be116534f7237b451f28adec91fbbbd.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_UPLOAD_REQUIRED=1

# Client-side backup encryption (age). The recipient (public key) encrypts;
# the private key in AGE_KEY_FILE decrypts and must stay OUT of the bucket.
# Generate once: age-keygen -o /etc/surau-backup/age.key  (chmod 600)
# and keep an offline escrow copy of age.key (password manager).
AGE_RECIPIENT=
AGE_KEY_FILE=/etc/surau-backup/age.key

# Telegram bot for alarms & reports (operator decision O-F1-1).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dead-man switch: alert when the newest R2 backup is older than this.
MAX_BACKUP_AGE_HOURS=26
