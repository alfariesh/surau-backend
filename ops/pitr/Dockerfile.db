# Postgres image with pgBackRest for continuous WAL archiving / PITR (E3).
# Built on the VPS by `docker compose build db`; the pgBackRest config
# (with R2 credentials + repo cipher passphrase) is NOT baked in — it is
# mounted from /etc/surau-backup/pgbackrest.conf at runtime.
FROM postgres:18.4-alpine

RUN apk add --no-cache pgbackrest \
  && mkdir -p /var/log/pgbackrest /var/spool/pgbackrest \
  && chown -R postgres:postgres /var/log/pgbackrest /var/spool/pgbackrest
