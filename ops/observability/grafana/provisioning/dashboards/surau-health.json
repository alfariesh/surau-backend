{
 "uid": "surau-health",
 "title": "Surau Health",
 "timezone": "browser",
 "schemaVersion": 39,
 "version": 1,
 "refresh": "30s",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "panels": [
  {
   "id": 1,
   "title": "Request rate per route",
   "type": "timeseries",
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 12,
    "h": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(http_requests_total[5m])) by (path)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{path}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "reqps"
    },
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 2,
   "title": "Error rate (5xx %)",
   "type": "timeseries",
   "gridPos": {
    "x": 12,
    "y": 0,
    "w": 6,
    "h": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "100 * sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 0.0001)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "5xx %"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percent"
    },
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 3,
   "title": "p95 latency",
   "type": "timeseries",
   "gridPos": {
    "x": 18,
    "y": 0,
    "w": 6,
    "h": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "p95"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 4,
   "title": "Email queue",
   "type": "timeseries",
   "gridPos": {
    "x": 0,
    "y": 8,
    "w": 8,
    "h": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "surau_email_queued",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "queued"
    },
    {
     "refId": "B",
     "expr": "surau_email_retrying",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "retrying"
    },
    {
     "refId": "C",
     "expr": "surau_email_failed",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "failed (dead letter)"
    }
   ],
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 5,
   "title": "Oldest due email age",
   "type": "timeseries",
   "gridPos": {
    "x": 8,
    "y": 8,
    "w": 4,
    "h": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "surau_email_oldest_due_seconds",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "oldest due"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 6,
   "title": "Background loop \u2014 seconds since last success",
   "type": "timeseries",
   "gridPos": {
    "x": 12,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "time() - surau_loop_last_success_timestamp_seconds",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{loop}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 7,
   "title": "Disk free %",
   "type": "timeseries",
   "gridPos": {
    "x": 0,
    "y": 16,
    "w": 6,
    "h": 7
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "100 * node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "free %"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percent"
    },
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 8,
   "title": "Backup age (hours)",
   "type": "timeseries",
   "gridPos": {
    "x": 6,
    "y": 16,
    "w": 6,
    "h": 7
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "(time() - surau_backup_last_success_timestamp) / 3600",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "daily dump"
    },
    {
     "refId": "B",
     "expr": "(time() - surau_pitr_check_last_success_timestamp) / 3600",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "pitr check"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "h"
    },
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 9,
   "title": "Host memory available",
   "type": "timeseries",
   "gridPos": {
    "x": 12,
    "y": 16,
    "w": 6,
    "h": 7
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "100 * node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "mem available %"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percent"
    },
    "overrides": []
   },
   "options": {}
  },
  {
   "id": 10,
   "title": "Host CPU busy %",
   "type": "timeseries",
   "gridPos": {
    "x": 18,
    "y": 16,
    "w": 6,
    "h": 7
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "cpu busy"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percent"
    },
    "overrides": []
   },
   "options": {}
  }
 ],
 "tags": [
  "surau",
  "f1-b"
 ]
}